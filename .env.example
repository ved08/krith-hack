DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Gemini — required unless MOCK_LLM=true
GEMINI_API_KEY=

# Set to "true" during offline development; the agent will use a deterministic
# keyword-matched mock model and never hit the real Gemini API.
MOCK_LLM=false

# HTTP port for the Hono server (defaults to 3000)
PORT=3000

# Twilio REST API credentials — required to actually send WhatsApp replies.
# Leave blank to fall back to a console dry-run (no messages sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number Twilio gave you. Must include the "whatsapp:" prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Supabase Storage — used for uploading Learning DNA certificate PDFs.
# SUPABASE_URL is your project REST URL (https://<ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" key, server-side only.
# Leave both blank to fall back to a console dry-run (PDF generated, not uploaded).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Storage bucket name. Created automatically on first upload if missing.
SUPABASE_CERTIFICATES_BUCKET=certificates

# Daily parent attendance broadcast scheduler.
# 6 PM daily by default (`0 18 * * *`) using the timezone below.
ATTENDANCE_CRON_ENABLED=true
ATTENDANCE_CRON_EXPRESSION=0 18 * * *
ATTENDANCE_CRON_TIMEZONE=Asia/Kolkata
