DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Gemini — required unless MOCK_LLM=true
GEMINI_API_KEY=

# Set to "true" during offline development; the agent will use a deterministic
# keyword-matched mock model and never hit the real Gemini API.
MOCK_LLM=false

# HTTP port for the Hono server (defaults to 3000)
PORT=3000

# Twilio REST API credentials — required to actually send WhatsApp replies.
# Leave blank to fall back to a console dry-run (no messages sent).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Sender number Twilio gave you. Must include the "whatsapp:" prefix.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
