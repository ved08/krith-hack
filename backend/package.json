{
  "name": "campus-cortex-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun x drizzle-kit generate",
    "db:push": "bun x drizzle-kit push",
    "db:apply": "bun run src/db/apply-migrations.ts",
    "db:studio": "bun x drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  }
}
